.page {
  min-height: 100vh;
  padding: 32rpx 24rpx;
  box-sizing: border-box;
  background: #f7f4ee;
}

.panel {
  padding: 32rpx;
  border: 1rpx solid #e1dacd;
  border-radius: 12rpx;
  background: #fffdf8;
}

.title {
  display: block;
  margin-bottom: 24rpx;
  color: #20201d;
  font-size: 40rpx;
  font-weight: 700;
}

.body {
  display: block;
  margin-bottom: 20rpx;
  color: #4f4b43;
  font-size: 28rpx;
  line-height: 1.7;
}
