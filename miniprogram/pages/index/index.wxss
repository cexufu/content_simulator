.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 56rpx;
  box-sizing: border-box;
}

.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.eyebrow {
  display: block;
  color: #6d6a60;
  font-size: 22rpx;
  line-height: 1.4;
}

.title {
  display: block;
  margin-top: 6rpx;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.15;
}

.status {
  flex: 0 0 auto;
  padding: 12rpx 18rpx;
  border: 1rpx solid #d6d0c3;
  border-radius: 999rpx;
  color: #6d6a60;
  font-size: 22rpx;
}

.status.online {
  border-color: #8eaa92;
  color: #356b54;
  background: #edf5ef;
}

.status.busy {
  border-color: #c8a650;
  color: #805f14;
  background: #fff7dc;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(32, 32, 29, 0.42);
}

.modal {
  width: 100%;
  padding: 36rpx;
  border-radius: 12rpx;
  background: #fffdf8;
  box-shadow: 0 24rpx 70rpx rgba(32, 32, 29, 0.18);
}

.modal-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.modal-text,
.modal-note {
  display: block;
  margin-bottom: 18rpx;
  color: #4f4b43;
  font-size: 28rpx;
  line-height: 1.65;
}

.modal-note {
  color: #8a5a3d;
}

.tabs,
.switcher,
.type-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.clear-btn {
  width: 100%;
  margin-bottom: 24rpx;
}

.tab,
.switch,
.type {
  flex: 1;
  min-width: 0;
  padding: 18rpx 10rpx;
  border: 1rpx solid #d8d1c3;
  border-radius: 10rpx;
  color: #5f5a50;
  background: #fffaf0;
  text-align: center;
  font-size: 26rpx;
}

.tab.active,
.switch.active,
.type.active {
  border-color: #20201d;
  color: #fff;
  background: #20201d;
}

.section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.panel {
  padding: 24rpx;
  border: 1rpx solid #e1dacd;
  border-radius: 12rpx;
  background: #fffdf8;
}

.panel-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.panel-title {
  color: #20201d;
  font-size: 32rpx;
  font-weight: 700;
}

.panel-sub {
  color: #7c766b;
  font-size: 22rpx;
}

.textarea,
.input {
  min-height: 220rpx;
  margin-bottom: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #d8d1c3;
  border-radius: 10rpx;
  background: #fbf8f1;
  line-height: 1.6;
}

.textarea.small {
  min-height: 140rpx;
}

.input {
  min-height: auto;
  height: 82rpx;
}

.primary,
.secondary,
.ghost {
  height: 76rpx;
  padding: 0 24rpx;
}

.primary {
  color: #fff;
  background: #20201d;
}

.secondary {
  color: #20201d;
  border: 1rpx solid #cfc7b8;
  background: #f0eadf;
}

.ghost {
  color: #4f4b43;
  border: 1rpx solid #ddd5c8;
  background: transparent;
}

.tiny {
  width: auto;
  height: 58rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}

.full {
  width: 100%;
  margin-top: 18rpx;
}

.hint,
.empty {
  display: block;
  color: #7c766b;
  font-size: 24rpx;
  line-height: 1.5;
}

.source {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #eee7dc;
}

.source-title,
.source-meta {
  display: block;
}

.source-title {
  font-weight: 700;
  line-height: 1.4;
}

.source-meta {
  margin-top: 6rpx;
  color: #7c766b;
  font-size: 24rpx;
}

.score-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.score-line {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
  font-size: 24rpx;
}

.bar {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9e2d6;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #356b54;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.chip,
.rule {
  display: inline-flex;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #edf1ed;
  color: #356b54;
  font-size: 24rpx;
}

.rule {
  background: #f4ebdf;
  color: #8a5a3d;
}

.feature-block,
.output-block,
.research {
  padding: 18rpx 0;
  border-top: 1rpx solid #eee7dc;
}

.block-title {
  display: block;
  margin-bottom: 10rpx;
  font-weight: 700;
}

.feature,
.draft-text {
  display: block;
  color: #3d3933;
  font-size: 26rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.chat-log {
  max-height: 520rpx;
  overflow: auto;
  padding: 12rpx 0;
}

.message {
  width: fit-content;
  max-width: 88%;
  margin-bottom: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  line-height: 1.55;
}

.message.ai {
  color: #3d3933;
  background: #f0eadf;
}

.message.user {
  margin-left: auto;
  color: #fff;
  background: #20201d;
}

.chat-row {
  display: flex;
  gap: 12rpx;
  margin: 12rpx 0 18rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8d1c3;
  border-radius: 10rpx;
  background: #fbf8f1;
}

.send {
  flex: 0 0 132rpx;
  height: 72rpx;
}

.news-card,
.topic {
  display: block;
  padding: 20rpx 0;
  border-top: 1rpx solid #eee7dc;
}

.topic-status {
  display: block;
  margin-top: 14rpx;
  color: #7c766b;
  font-size: 24rpx;
  line-height: 1.5;
}

.news-source {
  display: block;
  margin-bottom: 8rpx;
  color: #7c766b;
  font-size: 22rpx;
}

.news-title,
.topic-title {
  display: block;
  font-weight: 700;
  line-height: 1.5;
}

.news-body,
.topic-body {
  display: block;
  margin-top: 8rpx;
  color: #5f5a50;
  font-size: 26rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.topic-score,
.topic-link {
  display: inline-block;
  margin-top: 10rpx;
  margin-right: 10rpx;
  padding: 5rpx 12rpx;
  border: 1rpx solid #d8d1c3;
  border-radius: 999rpx;
  color: #5f5a50;
  background: #f7f1e6;
  font-size: 22rpx;
  line-height: 1.4;
}

.topic-link {
  color: #356b54;
}

.topic-actions,
.output-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.output .panel-head {
  margin-bottom: 8rpx;
}

.thinking {
  margin: 12rpx 0;
  padding: 18rpx;
  border-radius: 10rpx;
  color: #5f5a50;
  background: #f3efe7;
  font-size: 24rpx;
  line-height: 1.6;
}

.final {
  margin-top: 10rpx;
  padding: 20rpx;
  border: 1rpx solid #d8d1c3;
  border-radius: 10rpx;
  background: #fbf8f1;
}
