page {
  background: #f7f4ee;
  color: #20201d;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

button {
  margin: 0;
  border-radius: 10rpx;
  font-size: 28rpx;
  line-height: 1;
}

button::after {
  border: 0;
}

textarea,
input {
  box-sizing: border-box;
  width: 100%;
  color: #20201d;
  font-size: 28rpx;
}
